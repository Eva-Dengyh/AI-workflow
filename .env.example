# ========== 必填 ==========
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ========== 模型接入（可选）==========

# 第三方中转站 URL（兼容 Anthropic API 格式的代理）
# 不填则直连官方：https://api.anthropic.com
# 示例：ANTHROPIC_BASE_URL=https://your-relay.com
ANTHROPIC_BASE_URL=

# 使用的 Claude 模型
TASK_AGENT_MODEL=claude-opus-4-6

# Developer Agent 最大重试次数
TASK_AGENT_MAX_DEV_RETRY=5

# 任务目录（相对于项目根目录）
TASK_AGENT_TASKS_DIR=./tasks

# 日志级别 DEBUG|INFO|WARNING|ERROR
TASK_AGENT_LOG_LEVEL=INFO
